# ── MySQL 数据库配置 ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=请替换为强密码
MYSQL_USER=silviculture
MYSQL_PASSWORD=请替换为强密码

# ── 应用数据库连接（Docker 内部网络使用 db 作为主机名）──────────
DATABASE_URL=mysql://silviculture:请替换为强密码@db:3306/silviculture

# ── JWT 密钥（随机字符串，至少 32 字符）─────────────────────────
JWT_SECRET=请替换为随机字符串至少32字符

# ── 管理员（教师）登录凭据 ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置管理员密码

# ── 文件上传目录 ───────────────────────────────────────────────
# Docker 部署时使用容器内路径，会自动挂载 volume
UPLOAD_DIR=/app/uploads

# ── 前端显示信息（可选）────────────────────────────────────────
VITE_APP_TITLE=森林培育学知识问答系统

# ── LLM 配置说明 ──────────────────────────────────────────────
# LLM 模型通过教师后台界面配置，支持以下提供商：
# - OpenAI (需要 API Key)
# - DeepSeek (需要 API Key, 推荐国内使用)
# - 通义千问 Qwen (需要 API Key)
# - Ollama (本地部署，无需 API Key)
# - 自定义 OpenAI 兼容 API
#
# 首次部署后，登录教师后台 → 模型配置 → 添加并激活一个 LLM 配置
